{
  "name": "askdb-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx scripts/dev-runner.ts",
    "dev:server": "UI_DEV_MIDDLEWARE=1 pnpm --filter @askdb/server dev",
    "dev:ui": "pnpm --filter @askdb/ui dev",
    "build": "pnpm -r build",
    "start": "SERVE_UI=1 pnpm --filter @askdb/server start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @askdb/mcp-server test",
    "db:generate": "pnpm --filter @askdb/shared db:generate",
    "db:migrate": "pnpm --filter @askdb/shared db:migrate",
    "db:studio": "pnpm --filter @askdb/shared db:studio"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
