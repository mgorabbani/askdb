{
  "name": "@askdb/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts",
    "./adapters/mongodb": "./src/adapters/mongodb/index.ts",
    "./adapters/mongodb/sync": "./src/adapters/mongodb/sync.ts",
    "./adapters/mongodb/introspect": "./src/adapters/mongodb/introspect.ts",
    "./crypto/encryption": "./src/crypto/encryption.ts",
    "./auth/api-keys": "./src/auth/api-keys.ts",
    "./docker/manager": "./src/docker/manager.ts",
    "./pii/patterns": "./src/pii/patterns.ts",
    "./memory/extractor": "./src/memory/extractor.ts",
    "./memory/insights": "./src/memory/insights.ts",
    "./schema-summary/generator": "./src/schema-summary/generator.ts",
    "./test-support/sqlite-fixture": "./src/support/sqlite-fixture.ts"
