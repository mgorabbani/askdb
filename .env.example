# askdb environment configuration
# Copy to .env and fill in real values for production.

# ── Server ──────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ── Database ────────────────────────────────────────
# SQLite file path. Relative paths resolve from repo root.
DATABASE_PATH=./data/askdb.db

# ── Auth (better-auth) ──────────────────────────────
# BETTER_AUTH_SECRET and ENCRYPTION_KEY are auto-generated on first container
# boot into the askdb-data volume at /app/data/.secrets.
# To rotate: stop the container, delete the file, restart. This invalidates
# all existing sessions and encrypted connection strings.
# To provide your own, set them via docker compose `environment:` entries
# or another env_file; container-provided values take precedence.
BETTER_AUTH_URL=http://localhost:3100
# Comma-separated list of origins allowed to call /api/auth.
# Must include every browser origin you serve the UI from (no trailing slash).
# Example: TRUSTED_ORIGINS=https://askdb.example.com,https://www.askdb.example.com
TRUSTED_ORIGINS=http://localhost:3100,http://localhost:5173

# ── Encryption ──────────────────────────────────────
# (ENCRYPTION_KEY is auto-generated — see the BETTER_AUTH_SECRET note above.)

# ── Sandbox MongoDB containers ──────────────────────
# How long to wait for a freshly-spawned mongo container to accept connections.
# First-boot on a small VPS pulling the image can take 30-60s; default is 60.
SANDBOX_READY_TIMEOUT_SECONDS=60

# ── MCP endpoint ────────────────────────────────────
# For the default self-hosted setup, leave this unset. The server will
# advertise ${BETTER_AUTH_URL}/mcp as the MCP endpoint and clients will
# connect to it directly. Only set this if you front /mcp on a different
# hostname (rare).
# MCP_PUBLIC_URL=

# ── UI mode (advanced) ──────────────────────────────
# Dev: pnpm dev sets UI_DEV_MIDDLEWARE=1 automatically.
# Prod: pnpm start sets SERVE_UI=1 automatically. Don't set both.
# UI_DEV_MIDDLEWARE=1
# SERVE_UI=1
